{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/b/([^/]+)", "dest": "/store.html" },
    { "src": "/go/([^/]+)", "dest": "/open.html" },
    { "src": "/p/(.*)", "dest": "/sales.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
